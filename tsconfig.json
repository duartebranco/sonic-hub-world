{
    "compilerOptions": {
        "checkJs": true,
        "allowJs": true,
        "noEmit": true,
        "strict": false,
        "noImplicitAny": false,
        "moduleResolution": "bundler",
        "module": "esnext",
        "target": "es2022",
        "lib": ["es2022", "dom"],
        "paths": {
            "three": ["./node_modules/three/src/Three.Core.js"],
            "three/addons/*": ["./node_modules/three/examples/jsm/*"]
        }
    },
    "include": ["src/js/**/*.js"]
