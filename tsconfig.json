{
    "compilerOptions": {
        "checkJs": true,
        "allowJs": true,
        "noEmit": true,
        "strict": false,
        "noImplicitAny": false,
        "moduleResolution": "bundler",
        "module": "esnext",
        "target": "es2022",
        "lib": ["es2022", "dom", "dom.iterable"],
        "skipLibCheck": true,
        "paths": {
            "three/addons/*": ["./node_modules/three/examples/jsm/*"],
        },
    },
    "include": ["src/js/**/*.js"],
}
